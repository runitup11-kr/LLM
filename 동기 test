import asyncio
import time
import sys

sys.stdout.reconfigure(encoding="utf-8")

async def make_order(item, taken_time):
    print(f"{item} 접수")
    await asyncio.sleep(taken_time)
    print(f"{item} 준비완료")

async def main():
    start_time = time.time()
    result1 =  await make_order("라떼",3)
    result2 =  await make_order("아아",2)
    result3 =  await make_order("우유",1)
    elapsed_time = time.time() - start_time
    #print(result1, result2, result3)
    print(f"총 소요시간: {elapsed_time}")
       
#    result = await asyncio.gather(make_order("라떼" , 3), make_order("커피", 2), make_order("우유",1))
    
    
    
if __name__ == "__main__":
    asyncio.run(main())
