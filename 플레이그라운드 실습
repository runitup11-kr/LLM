"""
실습 P02: 모델 플레이그라운드 (- UI 리디자인 버전)

    - templates/index_v2.html  (새 마크업 구조)
    - static/style_v2.css      (다크 테크 테마 + 모델 pill 버튼 UI)

즉, /chat, /reset 라우트의 동작과 요청/응답 JSON 형식은 그대로이며,
어떤 템플릿을 렌더링할지(render_template 인자)만 바뀌었습니다.

바뀐 점 (UI 관점):
    - <select> 드롭다운 모델 선택 → 모델별 pill(알약형) 버튼 3개
    - temperature를 지원하지 않는 모델(sonnet/opus)을 고르면
      temperature 슬라이더를 시각적으로 흐리게(disabled 느낌) 표시
      → 실제 요청은 기존과 동일하게 항상 전송되며, 서버가 무시하는
        로직도 app2.py와 동일합니다. UI에서 "왜 안 먹히는지"를
        미리 알려주기 위한 표시일 뿐입니다.
    - 밝은 카드 UI → 다크 테마 + 네온 포인트 컬러
    - 응답 통계(⏱️, 토큰 수)를 말풍선 아래 작은 뱃지로 표시

바뀌지 않은 점 (기능 관점):
    - GET /            : 메인 페이지 렌더링
    - POST /chat        : 모델/파라미터를 받아 SSE로 스트리밍 응답
    - POST /reset       : 모델별 대화 히스토리 초기화
    - MODELS 딕셔너리, conversations 저장 구조, temperature 예외 처리 모두 동일
"""

import json
import time
from flask import Flask, render_template, request, Response, stream_with_context
from dotenv import load_dotenv
from anthropic import Anthropic, APIStatusError

load_dotenv()

app = Flask(__name__)
client = Anthropic()

# 화면에서 선택할 수 있는 모델 목록입니다. (app2.py와 동일)
# supports_temperature가 False인 모델은 temperature를 API에 아예 전달하지
# 않습니다(기본값 1.0이 아닌 값을 보내면 400 에러가 나기 때문).
MODELS = {
    "haiku": {
        "id": "claude-haiku-4-5",
        "name": "Haiku 4.5",
        "description": "빠르고 저렴 — 간단한 작업에 적합",
        "supports_temperature": True,
    },
    "sonnet": {
        "id": "claude-sonnet-5",
        "name": "Sonnet 5",
        "description": "속도와 성능의 균형 — 범용/코딩",
        "supports_temperature": False,
    },
    "opus": {
        "id": "claude-opus-4-8",
        "name": "Opus 4.8",
        "description": "최고 성능 — 복잡한 추론에 적합",
        "supports_temperature": False,
    },
}

# 모델별 응답 차이를 비교하기 위해 세션과 모델 조합별로 히스토리를 나눕니다.
conversations: dict[str, list] = {}


@app.route("/")
def index():
    """새 UI(index_v2.html)로 모델/파라미터 조절 패널과 채팅 UI를 보여줍니다."""
    return render_template("index_v2.html", models=MODELS)


@app.route("/chat", methods=["POST"])
def chat():
    """선택한 모델과 파라미터로 호출하고, 응답을 SSE로 스트리밍합니다.
    (app2.py와 로직 동일 — UI만 바뀌었을 뿐 이 함수는 그대로입니다.)"""
    data = request.json
    model_key = data["model"]
    user_message = data["message"]
    temperature = float(data.get("temperature", 1.0))
    max_tokens = int(data.get("max_tokens", 1024))
    session_id = data.get("session_id", "default")

    conv_key = f"{session_id}_{model_key}"
    if conv_key not in conversations:
        conversations[conv_key] = []

    history = conversations[conv_key]
    history.append({"role": "user", "content": user_message})

    model_info = MODELS[model_key]

    # temperature는 지원하는 모델에만 실어 보냅니다.
    stream_kwargs = {
        "model": model_info["id"],
        "max_tokens": max_tokens,
        "messages": history,
    }
    if model_info["supports_temperature"]:
        stream_kwargs["temperature"] = temperature

    def generate():
        start_time = time.time()

        try:
            with client.messages.stream(**stream_kwargs) as stream:
                full_response = ""
                for text in stream.text_stream:
                    full_response += text
                    yield f"data: {json.dumps({'text': text})}\n\n"

                history.append({"role": "assistant", "content": full_response})

                elapsed = round(time.time() - start_time, 2)
                usage = stream.get_final_message().usage
                yield f"data: {json.dumps({'done': True, 'input_tokens': usage.input_tokens, 'output_tokens': usage.output_tokens, 'elapsed': elapsed})}\n\n"
        except APIStatusError as e:
            # 실패한 요청은 히스토리에서 제거하고, 기존과 동일하게
            # 에러 문구를 "text" 청크로 흘려보냅니다.
            history.pop()
            yield f"data: {json.dumps({'text': f'[에러] {e}'})}\n\n"
            yield f"data: {json.dumps({'done': True, 'input_tokens': 0, 'output_tokens': 0, 'elapsed': round(time.time() - start_time, 2)})}\n\n"

    return Response(
        stream_with_context(generate()),
        content_type="text/event-stream",
    )


@app.route("/reset", methods=["POST"])
def reset():
    """선택한 모델의 대화 히스토리를 초기화합니다."""
    data = request.json
    session_id = data.get("session_id", "default")
    model_key = data.get("model", "")
    conv_key = f"{session_id}_{model_key}"
    conversations.pop(conv_key, None)
    return {"status": "ok"}


if __name__ == "__main__":
    # app2.py(포트 5002)와 동시에 띄워도 충돌하지 않도록 5003번을 사용합니다.
    app.run(debug=True, port=5003)


# ============================================================
# REST API 명세 (app2.py와 완전히 동일)
# ============================================================
#
# 1. GET /
#    메인 페이지, 즉 모델/파라미터 조절 패널과 채팅 UI를 반환합니다.
#
#    Response: text/html
#
# ─────────────────────────────────────────────────────────────
#
# 2. POST /chat
#    선택한 모델과 파라미터로 Claude를 호출하고 SSE로 스트리밍합니다.
#
#    Request:
#      Content-Type: application/json
#      Body:
#      {
#        "model":       (string, 필수) 모델 키 — "haiku" | "sonnet" | "opus"
#        "message":     (string, 필수) 사용자 메시지
#        "temperature": (number, 선택) 0.0~1.0 (기본값 1.0, haiku에만 적용)
#        "max_tokens":  (number, 선택) 최대 출력 토큰 수 (기본값 1024)
#        "session_id":  (string, 선택) 세션 식별자 (기본값 "default")
#      }
#
#    Response:
#      Content-Type: text/event-stream
#      스트리밍 이벤트 (SSE):
#
#      [텍스트 청크] — 생성되는 텍스트 조각을 반복 전송
#        data: {"text": "응답 텍스트 조각"}
#
#      [완료] — 스트림 마지막에 1회 전송
#        data: {"done": true, "input_tokens": 25, "output_tokens": 130, "elapsed": 1.23}
#
#    sonnet/opus는 기본값(1.0) 외의 temperature를 요청해도 무시하고 호출합니다.
#
# ─────────────────────────────────────────────────────────────
#
# 3. POST /reset
#    특정 모델에 쌓인 대화 히스토리를 초기화합니다.
#
#    Request:
#      Content-Type: application/json
#      Body:
#      {
#        "model":      (string, 필수) 초기화할 모델 키
#        "session_id": (string, 선택) 세션 식별자 (기본값 "default")
#      }
#
#    Response:
#      Content-Type: application/json
#      {"status": "ok"}
